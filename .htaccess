# YZA — static site (yza-shop.com)
Options -Indexes
DirectoryIndex index.html index.htm

<IfModule mod_rewrite.c>
  RewriteEngine On

  # ---- Clean URLs: category pages (extensionless, query-string driven) ----
  RewriteRule ^collections/charms/?$             collections.html?cat=charms [QSA,L]
  RewriteRule ^collections/sacs/?$                collections.html?cat=bags [QSA,L]
  RewriteRule ^collections/pret-a-porter/?$      collections.html?cat=rtw [QSA,L]
  RewriteRule ^collections/bijoux/?$              collections.html?cat=accessories [QSA,L]
  RewriteRule ^collections/boucles-d-oreilles/?$ collections.html?cat=earrings [QSA,L]
  RewriteRule ^collections/colliers/?$            collections.html?cat=necklaces [QSA,L]
  RewriteRule ^collections/hauts/?$               collections.html?cat=tops [QSA,L]
  RewriteRule ^collections/jupes-pareo/?$         collections.html?cat=pareos [QSA,L]
  RewriteRule ^collections/pantalons/?$           collections.html?cat=pants [QSA,L]
  RewriteRule ^collections/bas/?$                 collections.html?cat=bottoms [QSA,L]

  # ---- Clean URLs: product detail pages ----
  RewriteRule ^produits/([a-zA-Z0-9-]+)/?$        produit.html?handle=$1 [QSA,L]

  # ---- Clean URLs: pages whose slug differs from the filename ----
  RewriteRule ^grossistes/?$        b2b.html [L]
  RewriteRule ^mentions-legales/?$  legal.html [L]
  RewriteRule ^journal/?$           blogs/journal/ [L]

  # ---- Clean URLs: generic — /{name} serves {name}.html when that file exists.
  # Covers /collections, /lookbook, /studio, /histoire, /yza-girls, /contact, /faq
  # without a rule per page. /dashboard is excluded on purpose (stays .html-only).
  RewriteCond %{REQUEST_URI} !^/dashboard
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^([a-zA-Z0-9_-]+)/?$ $1.html [L]

  # ---- Legacy Shopify URLs -> new static site (so old Google results / bookmarks
  # don't hit a 404). Runs last so it only catches genuinely-unknown legacy paths —
  # bare /collections is already handled by the generic rule above, and the clean
  # /collections/{category} routes further up already matched and exited by [L].
  RewriteRule ^collections/.+$           /collections.html [R=301,L]
  RewriteRule ^products/.+$              /collections.html [R=301,L]
  RewriteRule ^pages/.+$                 /                 [R=301,L]
  RewriteRule ^(cart|account|checkout)(/.*)?$ /            [R=301,L]
</IfModule>

ErrorDocument 404 /404.html

# Gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg   "access plus 1 month"
  ExpiresByType image/png    "access plus 1 month"
  ExpiresByType image/webp   "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType video/mp4    "access plus 1 month"
  # Short TTL on code so site updates go live in minutes, not a week
  # (assets carry a ?v= version query that is bumped when they change).
  ExpiresByType text/css     "access plus 10 minutes"
  ExpiresByType application/javascript "access plus 10 minutes"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

# Force a short cache on code (mod_expires alone is overridden by the host's
# 7-day static default). mod_headers "set" takes final precedence.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=600, must-revalidate"
  </FilesMatch>
  # HTML must never be cached at the server/CDN layer (LiteSpeed's own LSCache,
  # separate from the hcdn edge, was found serving a stale pre-migration
  # WordPress snapshot of "/" to some browsers weeks after the WP install was
  # removed — X-LiteSpeed-Cache-Control is the documented way to opt an
  # .htaccess-only site out of LSCache without the WP plugin present).
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set X-LiteSpeed-Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# Note: HTTPS is handled at the Hostinger panel level ("Force HTTPS").
# A redirect rule is intentionally omitted here to avoid a loop if SSL
# is still provisioning.
