# YZA — static site (yza-shop.com)
Options -Indexes
DirectoryIndex index.html index.htm

# Legacy Shopify URLs -> new static site (so old Google results / bookmarks
# don't hit a 404). Patterns require a slash after the keyword, so the real
# files (collections.html, produit.html) and /blogs/journal/ are untouched.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^collections/?$            /collections.html [R=301,L]
  RewriteRule ^collections/.+$           /collections.html [R=301,L]
  RewriteRule ^products/.+$              /collections.html [R=301,L]
  RewriteRule ^pages/.+$                 /                 [R=301,L]
  RewriteRule ^(cart|account|checkout)(/.*)?$ /            [R=301,L]
</IfModule>

ErrorDocument 404 /404.html

# Gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg   "access plus 1 month"
  ExpiresByType image/png    "access plus 1 month"
  ExpiresByType image/webp   "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType video/mp4    "access plus 1 month"
  # Short TTL on code so site updates go live in minutes, not a week
  # (assets carry a ?v= version query that is bumped when they change).
  ExpiresByType text/css     "access plus 10 minutes"
  ExpiresByType application/javascript "access plus 10 minutes"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

# Note: HTTPS is handled at the Hostinger panel level ("Force HTTPS").
# A redirect rule is intentionally omitted here to avoid a loop if SSL
# is still provisioning.
